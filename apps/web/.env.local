# Environment variables for Canton AI Agent Wallet
# Copy this file to .env.local and fill in values

# Application
NEXT_PUBLIC_APP_NAME="Canton Agent Wallet"
NEXT_PUBLIC_APP_ENV="development"

# Database
DATABASE_URL="file:./data/wallet.db"

# ─── Loop SDK Integration ────────────────────────────────────────────────────────
# Controls whether Loop wallet integration is enabled.
# When false, app runs in demo mode only (no real wallet).
NEXT_PUBLIC_LOOP_ENABLED="false"

# Loop network: 'testnet' | 'mainnet' | 'local'
NEXT_PUBLIC_LOOP_NETWORK="testnet"

# How to open Loop wallet popup: 'popup' | 'tab' | 'overlay'
NEXT_PUBLIC_LOOP_OPEN_MODE="popup"

# Signing mode: 'browser' (local key) | 'server' (remote signing)
NEXT_PUBLIC_LOOP_REQUEST_SIGNING_MODE="browser"

# Server-side signing (EXPERIMENTAL — requires SERVER_SIGNING_PRIVATE_KEY)
# Never enable this without proper secret management.
LOOP_SERVER_SIGNING_ENABLED="false"
LOOP_SERVER_SIGNING_URL=""
# SERVER_SIGNING_PRIVATE_KEY=""   # Set in .env.local only, never committed

# Feature Flags
NEXT_PUBLIC_FEATURE_MOCK_MARKET="true"
NEXT_PUBLIC_FEATURE_LIVE_WALLET="false"
NEXT_PUBLIC_FEATURE_LLM_PARSER="false"
NEXT_PUBLIC_FEATURE_DAML_INTEGRATION="false"

# Demo wallet address (shown in demo mode)
NEXT_PUBLIC_DEMO_WALLET_ADDRESS="0xDEMO0000000000000000000000000000000"
NEXT_PUBLIC_DEMO_BALANCE_CC="500"
